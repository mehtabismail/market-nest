{
  "expo": {
    "name": "MarketNest",
    "slug": "marketnest",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "marketnest",
    "backgroundColor": "#060d09",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marketnest.app"
    },
    "android": {
      "package": "com.marketnest.app",
      "adaptiveIcon": {
        "backgroundColor": "#060d09",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "MarketNest needs access to your photos so you can add product images and upload verification documents.",
          "cameraPermission": "MarketNest needs camera access so you can photograph products and verification documents."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-native.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#030906",
          "dark": {
            "image": "./assets/splash-native.png",
            "backgroundColor": "#030906"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001"
    }
  }
}
