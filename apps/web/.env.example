# Web uses the repo root .env only (do not duplicate secrets here).
#
#   npm run env:setup     # from repo root → creates /.env
#   # Edit /.env with your keys
#
# Variables read by @marketnest/web (all in root .env):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   NEXT_PUBLIC_API_URL
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
