# API uses the repo root .env (do not duplicate secrets here).
#
#   npm run env:setup     # from repo root → creates /.env + links apps/api/.env
#   npm run env:link      # re-link after editing root .env
#   # Edit /.env with your keys
#
# Prisma (`npx prisma db push` from apps/api) reads apps/api/.env → symlink to root.
#
# Variables read by @marketnest/api (all in root .env):
#   DATABASE_URL, DIRECT_URL
#   NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#   REDIS_URL, API_PORT, CORS_ORIGIN, JWT_SECRET
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#   SENDGRID_*, TWILIO_*, SELLER_INVITE_REDIRECT_URL
#   RATE_LIMIT_ENABLED (true|false, default true)
#   SEED_SUPERADMIN_EMAIL, SEED_SUPERADMIN_PASSWORD
