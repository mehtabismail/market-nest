# =============================================================================
# MarketNest — single environment file (repo root)
# =============================================================================
#
# Setup:
#   npm run env:setup          # copies this file to .env
#   npm run env:link           # links apps/api/.env for Prisma CLI
#   # Fill in values below, then:
#   npm run dev
#
# Apps load this file automatically (no separate apps/api/.env required):
#   - API:  ConfigModule + scripts/env/load-root-env.cjs (Prisma)
#   - Web:  next.config.mjs
#   - Turbo: loads root .env when running npm run dev
#
# Tags: [api] [web] [both] [optional]
# =============================================================================

# --- Supabase [both] ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dashboard → API → service_role (SECRET — API only, never expose to browser) [api]
SUPABASE_SERVICE_ROLE_KEY=

# --- PostgreSQL (Supabase) [api] ---
# Dashboard → Database → Connect → use the *pooler* host (aws-*.pooler.supabase.com):
# For Nest (long-lived): Session mode port **5432** + connection_limit=5&connect_timeout=15
DATABASE_URL=
# DIRECT_URL = also Session pooler :5432 (same host). Used by Prisma migrate/db push.
# Do NOT use db.<ref>.supabase.co — often IPv6-only / unreachable → Prisma P1001 flaps.
# Avoid Transaction mode :6543 for the API process — much slower for persistent PrismaClient.
DIRECT_URL=

# --- Redis (Upstash recommended) [api] ---
# Use rediss:// (TLS) from Upstash dashboard — not redis://
REDIS_URL=

# --- API server [api] ---
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=

# --- Rate limiting [api] ---
# true = enforce Redis rate limits (default). false = disable for local testing.
# Also bypasses Supabase auth emails — invite links are shown in Admin UI instead.
RATE_LIMIT_ENABLED=true

# Optional override: force Supabase email bypass on/off regardless of RATE_LIMIT_ENABLED
# AUTH_EMAIL_BYPASS=true

# --- Web → API [web] ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Stripe [api] + publishable [web] ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email / SMS (Phase 3 — skipped if empty) [api] ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=orders@marketnest.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- AI (Phase 4+) [optional] ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- OAuth (future) [optional] ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Seller invites [api] ---
SELLER_INVITE_REDIRECT_URL=http://localhost:3000/seller/set-password

# --- Password reset redirect [api] ---
AUTH_RESET_REDIRECT_URL=http://localhost:3000/shop/reset-password

# --- Database seed (optional) [api] ---
SEED_SUPERADMIN_EMAIL=admin@marketnest.com
SEED_SUPERADMIN_PASSWORD=

# --- Runtime [optional] ---
NODE_ENV=development
